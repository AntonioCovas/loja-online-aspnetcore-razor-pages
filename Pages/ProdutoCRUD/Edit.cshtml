@page
@model AspNetCoreWebApp.Pages.ProdutoCRUD.EditModel
@{
    ViewData["Titulo"] = "Alterar Produto";
}

<main class="container mt-3">
    <div class="row justify-content-center">
        <div class="col-sm-12">
            <h1>@ViewData["Titulo"]</h1>
            <form method="post" class="mt-3">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Produto.Id" />
                <div class="form-group">
                    <label asp-for="Produto.Nome" class="control-label"></label>
                    <input asp-for="Produto.Nome" class="form-control col-6" />
                    <span asp-validation-for="Produto.Nome" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Produto.Descricao" class="control-label"></label>
                    <input asp-for="Produto.Descricao" class="form-control col-6" />
                    <span asp-validation-for="Produto.Descricao" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Produto.Preco" class="control-label"></label>
                    <input asp-for="Produto.Preco" class="form-control col-3" type="text" />
                    <span asp-validation-for="Produto.Preco" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Produto.Estoque" class="control-label"></label>
                    <input asp-for="Produto.Estoque" class="form-control col-4" />
                    <span asp-validation-for="Produto.Estoque" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <a asp-page="./Index" class="btn btn-info">Cancelar</a>
                    <input type="submit" value="Salvar" class="btn btn-primary" />
                </div>
            </form>
        </div>
    </div>
</main>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
